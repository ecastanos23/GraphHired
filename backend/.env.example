# COMENTARIO DE ARCHIVO - GRAPHHIRED
# Plantilla de variables de entorno del backend. Partes: conexion a PostgreSQL, clave secreta de desarrollo y configuracion minima para levantar FastAPI sin exponer secretos reales.

# Database
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=graphhired
DB_HOST=db
DB_PORT=5432

# Backend
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-here

# API Keys (if needed)
# GEMINI_API_KEY=
# OTHER_API_KEY=
